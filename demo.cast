[0.001, "o", "    analyze-single-tc \u001b[36mdest\u001b[0m=\u001b[32mdest\u001b[0m        \u001b[34m#\u001b[0m \u001b[34mSelect a failed TC with fzf, run it with csql, and analyze with claude\u001b[0m\r\n    browse-reports \u001b[36mreports\u001b[0m=\u001b[32m\"./reports\"\u001b[0m \u001b[34m#\u001b[0m \u001b[34mInteractively browse and open failure reports in $EDITOR\u001b[0m\r\n    clean                              \u001b[34m#\u001b[0m \u001b[34mRemove generated output files\u001b[0m\r\n    clone                              \u001b[34m#\u001b[0m \u001b[34mUsage: just clone src=/path/to/cubrid/sql\u001b[0m\r\n    default                            \u001b[34m#\u001b[0m \u001b[34mShow available recipes\u001b[0m\r\n    fetch                              \u001b[34m#\u001b[0m \u001b[34mUsage: just fetch pr=https://github.com/CUBRID/cubrid/pull/6904\u001b[0m\r\n    pick                               \u001b[34m#\u001b[0m \u001b[34mPick a TC with fzf (run in a separate terminal/zellij pane, then trigger /analyze-tc in Claude Code)\u001b[0m\r\n    run-ctp-sql\r\n    run-fetch-clone                    \u001b[34m#\u001b[0m \u001b[34mUsage: just run pr=https://github.com/CUBRID/cubrid/pull/6904 src=/path/to/cubrid/sql\u001b[0m\r\n    serve\r\n"]
